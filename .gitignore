# Lake build outputs
/.lake
packages/*/.lake/

# Vendored native crypto sources for the LeanHazmat families. Fetched
# shallow at a pinned tag by `just vendor-<family>` into a gitignored
# `vendor/` tree (hazmat-docs/ARCHITECTURE.md §6); never committed, never
# a git submodule. The pin lives in the `just vendor-*` recipe.
packages/*/vendor/
# LeanPoseidon's Rust conformance-oracle build output (cargo). The
# vendored `Cargo.lock` is committed for reproducible oracle builds;
# only the build directory is ignored.
packages/LeanPoseidon/rust-oracle/target/

# Per-subpackage `lake-manifest.json` files are auto-regenerated by
# Lake when building from the umbrella; only the top-level
# `lake-manifest.json` is checked in (per CLAUDE.md's dep policy).
packages/*/lake-manifest.json
# Exception: `LeanSha256` is mirror-published as a standalone Lake
# package at `github.com/etheorem/LeanSha256` (subtree-split from this
# monorepo). The downstream repo needs a `lake-manifest.json` at its
# root for Reservoir inclusion + reproducible builds, so we ship the
# subpackage's manifest with the source. LeanSha256 has zero
# dependencies, so the manifest is effectively static — regenerate
# with `cd packages/LeanSha256 && lake update` if that ever changes.
!packages/LeanSha256/lake-manifest.json
# Exception: `LeanPoseidonProofs` is a standalone (mathlib-bearing) package,
# built on its own rather than through the umbrella, so its manifest is the
# committed record of the exact mathlib (+ transitive) revisions — pinning
# the proof's dependency set for reproducible builds. Regenerate with
# `cd packages/LeanPoseidonProofs && lake update`.
!packages/LeanPoseidonProofs/lake-manifest.json

# Python virtual environment and bytecode caches
/.venv
__pycache__/
*.pyc
*.pyo

# Bench session output. TSVs accumulate every time `just sizzlean-bench` runs;
# they're working-session output, not curated baselines. Force-add a
# specific file with `git add -f` if you want to lock it in as a
# reference.
packages/SizzLean/bench/*.tsv

# Claude Code per-session state
.claude/

# Per-developer personal shortcut (symlink to local notes)
/mb

# Editor / IDE local state
.vscode/
.idea/
*.swp
*.swo
*~

# macOS Finder cruft
.DS_Store
