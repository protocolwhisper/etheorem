# Lake build outputs
/.lake
packages/*/.lake/

# Per-subpackage `lake-manifest.json` files are auto-regenerated by
# Lake when building from the umbrella; only the top-level
# `lake-manifest.json` is checked in (per CLAUDE.md's dep policy).
packages/*/lake-manifest.json
# Exception: `LeanSha256` is mirror-published as a standalone Lake
# package at `github.com/etheorem/LeanSha256` (subtree-split from this
# monorepo). The downstream repo needs a `lake-manifest.json` at its
# root for Reservoir inclusion + reproducible builds, so we ship the
# subpackage's manifest with the source. LeanSha256 has zero
# dependencies, so the manifest is effectively static — regenerate
# with `cd packages/LeanSha256 && lake update` if that ever changes.
!packages/LeanSha256/lake-manifest.json

# Python virtual environment and bytecode caches
/.venv
__pycache__/
*.pyc
*.pyo

# Bench session output. TSVs accumulate every time `just bench` runs;
# they're working-session output, not curated baselines. Force-add a
# specific file with `git add -f` if you want to lock it in as a
# reference.
packages/SizzLean/bench/*.tsv

# Claude Code per-session state
.claude/

# Per-developer personal shortcut (symlink to local notes)
/mb

# Editor / IDE local state
.vscode/
.idea/
*.swp
*.swo
*~

# macOS Finder cruft
.DS_Store
